generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id             String         @id @default(cuid())
  name           String?
  email          String?        @unique
  emailVerified  DateTime?
  image          String?
  password       String?
  role           String         @default("user")
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  accounts       Account[]
  documents      Document[]
  purchases      Purchase[]
  sessions       Session[]
  sharesSent     ShareAttempt[] @relation("ShareSender")
  sharesReceived ShareAttempt[] @relation("ShareReceiver")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Document {
  id            String         @id @default(cuid())
  title         String
  description   String
  preview       String
  price         Decimal        @db.Decimal(10, 2)
  currency      String         @default("XOF")
  fileUrl       String
  coverImageUrl String?
  fileSize      Int
  fileType      String
  encryptionKey String
  checksum      String
  author        String?
  category      String?
  tags          String[]
  pageCount     Int?
  language      String         @default("fr")
  viewCount     Int            @default(0)
  purchaseCount Int            @default(0)
  sellerId      String
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  publishedAt   DateTime?
  deletedAt     DateTime?
  seller        User           @relation(fields: [sellerId], references: [id])
  purchases     Purchase[]
  shareAttempts ShareAttempt[]

  @@index([sellerId])
  @@index([category])
  @@index([publishedAt])
}

model Purchase {
  id             String        @id @default(cuid())
  userId         String
  documentId     String
  purchaseToken  String        @unique @default(cuid())
  amount         Decimal       @db.Decimal(10, 2)
  currency       String
  paymentMethod  String
  paymentId      String?
  paymentStatus  String        @default("pending")
  maxDevices     Int           @default(3)
  deviceIds      String[]
  downloadCount  Int           @default(0)
  maxDownloads   Int           @default(5)
  watermark      String
  expiresAt      DateTime?
  shareAttemptId String?
  purchasedAt    DateTime      @default(now())
  lastAccessedAt DateTime?
  document       Document      @relation(fields: [documentId], references: [id])
  shareAttempt   ShareAttempt? @relation(fields: [shareAttemptId], references: [id])
  user           User          @relation(fields: [userId], references: [id])

  @@unique([userId, documentId])
  @@index([userId])
  @@index([documentId])
  @@index([purchaseToken])
}

model ShareAttempt {
  id          String     @id @default(cuid())
  fromUserId  String
  toEmail     String
  documentId  String
  toUserId    String?
  shareToken  String     @unique @default(cuid())
  status      String     @default("pending")
  message     String?
  createdAt   DateTime   @default(now())
  expiresAt   DateTime
  completedAt DateTime?
  purchases   Purchase[]
  document    Document   @relation(fields: [documentId], references: [id])
  fromUser    User       @relation("ShareSender", fields: [fromUserId], references: [id])
  toUser      User?      @relation("ShareReceiver", fields: [toUserId], references: [id])

  @@index([fromUserId])
  @@index([toEmail])
  @@index([shareToken])
}

model DownloadLog {
  id            String   @id @default(cuid())
  purchaseToken String
  deviceId      String
  deviceInfo    String?
  ipAddress     String?
  downloadedAt  DateTime @default(now())

  @@index([purchaseToken])
}

model AccessLog {
  id            String   @id @default(cuid())
  purchaseToken String
  action        String
  deviceId      String?
  ipAddress     String?
  metadata      String?
  timestamp     DateTime @default(now())

  @@index([purchaseToken])
  @@index([timestamp])
}
