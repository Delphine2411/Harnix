// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  password      String?
  role          String    @default("user") // "user", "seller", "admin"
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts      Account[]
  sessions      Session[]
  documents     Document[]
  purchases     Purchase[]
  sharesSent    ShareAttempt[] @relation("ShareSender")
  sharesReceived ShareAttempt[] @relation("ShareReceiver")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Document {
  id              String   @id @default(cuid())
  title           String
  description     String   @db.Text
  preview         String   @db.Text // Résumé visible avant achat
  price           Decimal  @db.Decimal(10, 2)
  currency        String   @default("XOF") // ou "USD", "EUR"
  
  // Fichiers
  fileUrl         String   // URL du fichier chiffré dans S3
  coverImageUrl   String?  // Image de couverture
  fileSize        Int      // Taille en bytes
  fileType        String   // "pdf", "epub", "docx"
  
  // Sécurité
  encryptionKey   String   // Clé de chiffrement (elle-même chiffrée)
  checksum        String   // Hash du fichier original
  
  // Métadonnées
  author          String?
  category        String?
  tags            String[] // Array de tags
  pageCount       Int?
  language        String   @default("fr")
  
  // Stats
  viewCount       Int      @default(0)
  purchaseCount   Int      @default(0)
  
  // Relations
  sellerId        String
  seller          User     @relation(fields: [sellerId], references: [id])
  purchases       Purchase[]
  shareAttempts   ShareAttempt[]
  
  // Timestamps
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  publishedAt     DateTime?
  
  // Soft delete
  deletedAt       DateTime?

  @@index([sellerId])
  @@index([category])
  @@index([publishedAt])
}

model Purchase {
  id              String   @id @default(cuid())
  
  // Relations
  userId          String
  documentId      String
  user            User     @relation(fields: [userId], references: [id])
  document        Document @relation(fields: [documentId], references: [id])
  
  // Token unique pour cette licence
  purchaseToken   String   @unique @default(cuid())
  
  // Paiement
  amount          Decimal  @db.Decimal(10, 2)
  currency        String
  paymentMethod   String   // "stripe", "fedapay"
  paymentId       String?  // ID de la transaction
  paymentStatus   String   @default("pending") // "pending", "completed", "failed", "refunded"
  
  // Contrôle d'accès
  maxDevices      Int      @default(3)
  deviceIds       String[] // Liste des appareils autorisés
  downloadCount   Int      @default(0)
  maxDownloads    Int      @default(5)
  
  // Watermarking
  watermark       String   // Email ou ID de l'utilisateur injecté dans le doc
  
  // Expiration (optionnel)
  expiresAt       DateTime?
  
  // Provenance (si c'est un partage)
  shareAttemptId  String?
  shareAttempt    ShareAttempt? @relation(fields: [shareAttemptId], references: [id])
  
  // Timestamps
  purchasedAt     DateTime @default(now())
  lastAccessedAt  DateTime?
  
  @@unique([userId, documentId]) // Un utilisateur ne peut acheter qu'une fois
  @@index([userId])
  @@index([documentId])
  @@index([purchaseToken])
}

model ShareAttempt {
  id              String   @id @default(cuid())
  
  // Relations
  fromUserId      String
  toEmail         String
  documentId      String
  fromUser        User     @relation("ShareSender", fields: [fromUserId], references: [id])
  toUser          User?    @relation("ShareReceiver", fields: [toUserId], references: [id])
  toUserId        String?
  document        Document @relation(fields: [documentId], references: [id])
  
  // Token de partage unique
  shareToken      String   @unique @default(cuid())
  
  // Statut
  status          String   @default("pending") // "pending", "purchased", "expired", "cancelled"
  
  // Message personnalisé
  message         String?  @db.Text
  
  // Timestamps
  createdAt       DateTime @default(now())
  expiresAt       DateTime // Lien expire après X jours
  completedAt     DateTime?
  
  // Relation avec l'achat résultant
  purchases       Purchase[]
  
  @@index([fromUserId])
  @@index([toEmail])
  @@index([shareToken])
}

model DownloadLog {
  id              String   @id @default(cuid())
  purchaseToken   String
  deviceId        String
  deviceInfo      String?  @db.Text // User agent, OS, etc.
  ipAddress       String?
  downloadedAt    DateTime @default(now())
  
  @@index([purchaseToken])
}

model AccessLog {
  id              String   @id @default(cuid())
  purchaseToken   String
  action          String   // "view", "download", "share_attempt"
  deviceId        String?
  ipAddress       String?
  metadata        String?  @db.Text // JSON avec infos supplémentaires
  timestamp       DateTime @default(now())
  
  @@index([purchaseToken])
  @@index([timestamp])
}